{
    "name": "jason/captcha",
    "type": "package",
    "description": "Laravel 10/11/12/13 Captcha Package",
    "keywords": [
        "laravel Captcha",
        "laravel Security",
        "Captcha"
    ],
    "homepage": "https://github.com/jasonencode/captcha",
    "license": "MIT",
    "authors": [
        {
            "name": "Jason.Chen",
            "email": "chenjxlg@gmail.com",
            "homepage": "https://github.com/jasonencode",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
        "intervention/image": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Jason\\Captcha\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Jason\\Captcha\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "minimum-stability": "stable",
    "extra": {
        "laravel": {
            "providers": [
                "Jason\\Captcha\\CaptchaServiceProvider"
            ],
            "aliases": {
                "Captcha": "Jason\\Captcha\\Facades\\Captcha"
            }
        }
    }
}
